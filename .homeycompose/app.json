{
  "id": "com.michel.ai-hub",
  "version": "1.0.0",
  "compatibility": ">=13.0.0",
  "sdk": 3,
  "runtime": "python",
  "platforms": ["local"],
  "permissions": ["homey:manager:api"],
  "pythonVersion": "3.14",
  "brandColor": "#1a73e8",
  "name": { "en": "Homey AI Hub" },
  "description": { "en": "Use Claude, OpenAI, and Ollama AI directly in your Homey Flows." },
  "category": "tools",
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "pythonPackages": [
    "anthropic>=0.84.0",
    "ollama>=0.6.1",
    "openai>=1.60.0",
    "httpx>=0.27.0"
  ],
  "api": {
    "post_save_settings": {
      "method": "POST",
      "path": "/save_settings"
    },
    "post_test_claude": {
      "method": "POST",
      "path": "/test_claude"
    },
    "post_test_ollama": {
      "method": "POST",
      "path": "/test_ollama"
    },
    "post_test_openai": {
      "method": "POST",
      "path": "/test_openai"
    },
    "get_ping": {
      "method": "GET",
      "path": "/ping"
    },
    "get_settings": {
      "method": "GET",
      "path": "/settings"
    },
    "post_webhook": {
      "method": "POST",
      "path": "/webhook"
    },
    "post_run_tests": {
      "method": "POST",
      "path": "/run_tests"
    }
  },
  "author": { "name": "Michel Helsdingen" },
  "source": "https://github.com/michelhelsdingen/homey-ai-hub",
  "bugs": { "url": "https://github.com/michelhelsdingen/homey-ai-hub/issues" }
}
